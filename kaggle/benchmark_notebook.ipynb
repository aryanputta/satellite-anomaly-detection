        "I load one telemetry file and list the expected run files. If I am outside Kaggle, I create a synthetic fallback so all cells remain executable.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "DATA_ROOT = '/kaggle/input/hybrid-satellite-telemetry/hybrid_satellite_dataset'\n",
        "RUNS_DIR = os.path.join(DATA_ROOT, 'satellite_runs')\n",
        "sample_path = os.path.join(RUNS_DIR, 'sat_01.csv')\n",
        "\n",
        "if os.path.exists(sample_path):\n",
        "    df = pd.read_csv(sample_path)\n",
        "    print('Using Kaggle dataset file:', sample_path)\n",
        "else:\n",
        "    print('Dataset not attached. Using synthetic fallback.')\n",
        "\n",
        "run_files = [f'sat_{i:02d}.csv' for i in range(1, 11)]\n",
        "print('Expected satellite runs:', run_files)\n",
        "\n",
        "sample_path = os.path.join(RUNS_DIR, 'sat_01.csv')\n",
        "print('Sample path:', sample_path)\n",
        "\n",
        "if os.path.exists(sample_path):\n",
        "    df = pd.read_csv(sample_path)\n",
        "else:\n",
        "    n = 5000\n",
        "    t = np.arange(n)\n",
        "    df = pd.DataFrame({\n",
        "        'timestamp': t,\n",
